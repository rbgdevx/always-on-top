{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime.version": "Lua 5.1",
  "runtime.nonstandardSymbol": [
    "!=",
    "continue",
    "//"
  ],
  "workspace.ignoreDir": [
    ".libraries",
    ".git",
    ".vscode",
    ".claude"
  ],
  "diagnostics.workspaceDelay": 3000,
  "diagnostics.disable": [
    "lowercase-global",
    "duplicate-set-field",
    "missing-fields",
    "inject-field",
    "cast-local-type",
    "param-type-mismatch",
    "return-type-mismatch"
  ],
  "diagnostics.globals": [
    "AlwaysOnTopDB",
    "SLASH_ALWAYSONTOP1",
    "SLASH_ALWAYSONTOP2",
    "SlashCmdList",
    "CreateFrame",
    "CreateAtlasMarkup",
    "CreateDataProvider",
    "ScrollUtil",
    "UIParent",
    "UISpecialFrames",
    "GameFontNormal",
    "GameFontNormalLarge",
    "GameFontHighlightLarge",
    "Settings",
    "StaticPopupDialogs",
    "StaticPopup_Show",
    "ReloadUI",
    "C_PvP",
    "C_Timer",
    "UnitGUID",
    "UnitFactionGroup",
    "hooksecurefunc",
    "AbbreviateNumbers",
    "PVPMatchScoreboard",
    "PVPMatchResults",
    "PVPMatchUtil",
    "PVPMatchTable",
    "PVPCellStatMixin",
    "PVPCellStringMixin",
    "PVPStringTemplate",
    "format",
    "wipe",
    "strsplit",
    "tinsert"
  ],
  "completion.callSnippet": "Replace",
  "completion.keywordSnippet": "Replace",
  "hint.enable": true,
  "hint.setType": true,
  "semantic.enable": true,
  "telemetry.enable": false
}
